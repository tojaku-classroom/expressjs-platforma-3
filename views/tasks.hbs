<div class='max-w-2xl mx-auto'>
  <h2 class='text-3xl font-bold text-slate-800 mb-6'>Zadaci</h2>

  {{#if error}}
    <div class='bg-red-100 border-red-400 text-red-700 px-4 py-3 rounded mb-4'>
      {{error}}
    </div>
  {{/if}}

  <form
    method='post'
    action='/tasks'
    class='space-y-4 bg-white rounded-lg shadow p-6 mb-8'
  >
    <div>
      <label for='title' class='block text-sm font-medium text-slate-700 mb-1'>
        Naslov
      </label>
      <input
        type='text'
        id='title'
        name='title'
        required='true'
        placeholder='Unesite naslov zadatka'
        class='w-full px-4 py-2 border border-slate-300 rounded focus:ring-blue-500 focus:border-transparent'
      />
    </div>

    <div>
      <label
        for='description'
        class='block text-sm font-medium text-slate-700 mb-1'
      >
        Opis
      </label>
      <textarea
        id='description'
        name='description'
        rows='3'
        placeholder='Unesite opis (nije obavezno)'
        class='w-full px-4 py-2 border border-slate-300 rounded focus:ring-blue-500 focus:border-transparent'
      ></textarea>
    </div>

    <button
      type='submit'
      class='w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition duration-200'
    >
      Spremi
    </button>
  </form>

  {{#if tasks.length}}
    <ul class='space-y-3'>
      {{#each tasks}}
        <li class='bg-white rounded-lg shadow p-4 flex items-start gap-4'>
          <!-- Označavanje dovršenosti -->
          <form method='post' action='/tasks/{{id}}/toggle' class='mt-1'>
            {{#if done}}
              <button
                type='submit'
                title='Označi kao nedovršeno'
                class='w-5 h-5 rounded border-2 shrink-0 bg-blue-600 border-blue-600'
              >
              </button>
            {{else}}
              <button
                type='submit'
                title='Označi kao dovršeno'
                class='w-5 h-5 rounded border-2 shrink-0 border-slate-400'
              >
              </button>
            {{/if}}
          </form>
          <!-- Podaci -->
          <div class='flex-1'>
            {{#if done}}
              <p class='font-semibold line-through text-slate-400'>{{title}}</p>
            {{else}}
              <p class='font-semibold text-slate-800'>{{title}}</p>
            {{/if}}
            {{#if description}}
              <p class='text-sm text-slate-500 mt-1'>{{description}}</p>
            {{/if}}
            <p class='text-sm text-slate-500 mt-1'>{{created_at}}</p>
          </div>
          <!-- Uređivanje i Brisanje -->
          <div class='flex gap-2'>
            <a
              href='/tasks/{{id}}/edit'
              class='text-sm text-blue-600 hover:underline'
            >Uredi</a>
            <form method='post' action='/tasks/{{id}}/delete'>
              <button
                type='submit'
                class='text-sm text-red-500 hover:underline'
              >Obriši</button>
            </form>
          </div>
        </li>
      {{/each}}
    </ul>
  {{else}}
    <p class='text-slate-500 text-center'>Nema zadataka. Možete dodati zadatak,
      ako želite.</p>
  {{/if}}
</div>