<div class="flex items-center justify-center min-h-[calc(100vh-250px)]">
  <div class="bg-white rounded-lg shadow-xl p-8 w-full max-w-md">
    <h2
      class="text-3xl font-bold text-slate-800 mb-6 text-center"
    >Registracija</h2>

    {{#if error}}
      <div
        class="bg-red-100 border-red-400 text-red-700 px-4 py-3 rounded mb-4"
      >
        {{error}}
      </div>
    {{/if}}

    <form method="post" action="/users/signup" class="space-y-4">
      <div>
        <label
          for="username"
          class="block text-sm font-medium text-slate-700 mb-1"
        >
          Korisničko ime
        </label>
        <input
          type="text"
          id="username"
          name="username"
          required="true"
          placeholder="Unesite korisničko ime"
          class="w-full px-4 py-2 border border-slate-300 rounded focus:ring-blue-500 focus:border-transparent"
        />
      </div>

      <div>
        <label
          for="email"
          class="block text-sm font-medium text-slate-700 mb-1"
        >
          E-mail adresa
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required="true"
          placeholder="Unesite e-mail adresu"
          class="w-full px-4 py-2 border border-slate-300 rounded focus:ring-blue-500 focus:border-transparent"
        />
      </div>

      <div>
        <label
          for="password"
          class="block text-sm font-medium text-slate-700 mb-1"
        >
          Zaporka
        </label>
        <input
          type="password"
          id="password"
          name="password"
          required="true"
          placeholder="Unesite zaporku"
          class="w-full px-4 py-2 border border-slate-300 rounded focus:ring-blue-500 focus:border-transparent"
        />
      </div>

      <button
        type="submit"
        class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition duration-200"
      >
        Registracija
      </button>
    </form>

    <p class="mt-6 text-center text-sm text-slate-600">
      Već imate korisnički račun?
      <a
        href="/users/signin"
        class="text-blue-600 hover:text-blue-700 font-medium"
      >Prijava korisnika</a>
    </p>
  </div>
</div>