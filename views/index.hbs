<div class="border border-blue-500 rounded-2xl shadow m-2 p-4">
  <h2 class="text-3xl font-bold mb-4">Testni podaci</h2>
  {{#if data}}
    <ul class="space-y-2">
      {{#each data}}
        <li class="p-4">
          <span>ID: {{this.id}} - {{this.title}}</span>
          {{#if this.description}}
            <p class="text-gray-700 mt-2">
              {{this.description}}
            </p>
          {{/if}}
        </li>
      {{/each}}
    </ul>
  {{else}}
    <p class="text-gray-700">Nema podataka</p>
  {{/if}}
</div>